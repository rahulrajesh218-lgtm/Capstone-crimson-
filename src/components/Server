import express from "express";
import cors from "cors";
import dotenv from "dotenv";
import OpenAI from "openai";

dotenv.config();

const app = express();
app.use(cors());
app.use(express.json());

const client = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

app.post("/api/chat", async (req, res) => {
  try {
    const { message, tasks } = req.body;

    const taskSummary =
      Array.isArray(tasks) && tasks.length > 0
        ? tasks
            .map(
              (task) =>
                `- ${task.title} | Subject: ${task.subject} | Due in: ${task.dueIn} day(s) | Status: ${task.status} | Priority: ${task.priority}`
            )
            .join("\n")
        : "No tasks available.";

    const prompt = `
You are Zentaskra AI, a helpful student study assistant.

Student's current tasks:
${taskSummary}

User message:
${message}

Give a helpful, short, clear answer. If relevant, use the student's tasks to personalize the response.
`;

    const response = await client.responses.create({
      model: "gpt-4.1-mini",
      input: prompt,
    });

    res.json({
      reply: response.output_text,
    });
  } catch (error) {
    console.error("OpenAI error:", error);
    res.status(500).json({
      error: "Failed to get AI response",
    });
  }
});

app.listen(3001, () => {
  console.log("Server running on http://localhost:3001");
});